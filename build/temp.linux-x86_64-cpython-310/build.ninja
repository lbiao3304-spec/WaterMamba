ninja_required_version = 1.3
cxx = c++
nvcc = /home/right_limit/miniconda3/envs/vmamba/bin/nvcc

cflags = -pthread -B /home/right_limit/miniconda3/envs/vmamba/compiler_compat -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /home/right_limit/miniconda3/envs/vmamba/include -fPIC -O2 -isystem /home/right_limit/miniconda3/envs/vmamba/include -fPIC -DWITH_CUDA -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include/TH -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include/THC -I/home/right_limit/miniconda3/envs/vmamba/include -I/home/right_limit/miniconda3/envs/vmamba/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=deform_conv_ext -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -DWITH_CUDA -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include/TH -I/home/right_limit/miniconda3/envs/vmamba/lib/python3.10/site-packages/torch/include/THC -I/home/right_limit/miniconda3/envs/vmamba/include -I/home/right_limit/miniconda3/envs/vmamba/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=deform_conv_ext -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_89,code=compute_89 -gencode=arch=compute_89,code=sm_89 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





build /home/right_limit/WaterMamba/build/temp.linux-x86_64-cpython-310/basicsr/models/ops/dcn/src/deform_conv_cuda.o: compile /home/right_limit/WaterMamba/basicsr/models/ops/dcn/src/deform_conv_cuda.cpp
build /home/right_limit/WaterMamba/build/temp.linux-x86_64-cpython-310/basicsr/models/ops/dcn/src/deform_conv_cuda_kernel.o: cuda_compile /home/right_limit/WaterMamba/basicsr/models/ops/dcn/src/deform_conv_cuda_kernel.cu
build /home/right_limit/WaterMamba/build/temp.linux-x86_64-cpython-310/basicsr/models/ops/dcn/src/deform_conv_ext.o: compile /home/right_limit/WaterMamba/basicsr/models/ops/dcn/src/deform_conv_ext.cpp







